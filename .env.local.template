# ============================================
# REQUIRED: Database Configuration
# ============================================
# Sign up at https://neon.tech and get your connection string
DATABASE_URL=postgresql://user:password@host/database

# ============================================
# REQUIRED: Better Auth Configuration
# ============================================
# Generate with: pnpm dlx @better-auth/cli secret
BETTER_AUTH_SECRET=your-secret-key-change-in-production-min-32-chars
BETTER_AUTH_URL=http://localhost:3000

# ============================================
# OPTIONAL: Cloudflare R2 Storage
# ============================================
# Only needed if using R2 for backups and LFS
# R2_ACCESS_KEY_ID=your_access_key_id
# R2_SECRET_ACCESS_KEY=your_secret_access_key
# R2_BUCKET_NAME=your_bucket_name
# R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com

# ============================================
# OPTIONAL: Git Repository Configuration
# ============================================
# Default: data/repos in project directory
# GIT_REPOS_PATH=/custom/path/to/git/repos
